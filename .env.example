# Groq API Configuration (FREE TIER: 14,400 requests/day)
# Get your FREE API key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# Optional: Override default model (default: llama3-8b-8192)
# Available free models: llama3-8b-8192, llama3-70b-8192, mixtral-8x7b-32768
# GROQ_MODEL=llama3-8b-8192

# Optional: Override max tokens (default: 1000)
# GROQ_MAX_TOKENS=1000

# Optional: Override temperature (default: 0.7)
# GROQ_TEMPERATURE=0.7

# IMPORTANT: Add these environment variables to Vercel:
# 1. Go to your Vercel project dashboard
# 2. Settings → Environment Variables
# 3. Add GROQ_API_KEY with your free API key from https://console.groq.com/keys
# 4. Deploy again after adding the variable
