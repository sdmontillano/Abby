# OpenAI API Configuration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Override default model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: Override max tokens (default: 1000)
# OPENAI_MAX_TOKENS=1000

# Optional: Override temperature (default: 0.7)
# OPENAI_TEMPERATURE=0.7

# IMPORTANT: Add these environment variables to Vercel:
# 1. Go to your Vercel project dashboard
# 2. Settings → Environment Variables
# 3. Add OPENAI_API_KEY with your actual API key
# 4. Deploy again after adding the variable
